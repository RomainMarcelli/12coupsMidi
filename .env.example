# =============================================================================
# MIDI MASTER — Variables d'environnement
# =============================================================================
# Copie ce fichier en .env.local (NE PAS COMMITTER .env.local).
# Remplis chaque valeur d'après ton projet Supabase.
# Redémarre `npm run dev` après chaque modification.
# =============================================================================

# ---------------------------------------------------------------------------
# SUPABASE — Client public (utilisé côté navigateur ET serveur)
# ---------------------------------------------------------------------------
# Où les trouver :
#   Dashboard Supabase → ton projet → Settings → API → "Project URL" / "anon public"
# Le préfixe NEXT_PUBLIC_ expose la variable au navigateur (c'est voulu pour
# la clé anon, qui est publique et protégée par les policies RLS).

NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# ---------------------------------------------------------------------------
# SUPABASE — Service Role (SECRET, serveur uniquement)
# ---------------------------------------------------------------------------
# Où la trouver :
#   Dashboard Supabase → Settings → API → "service_role" (révélation manuelle)
# ⚠️ BYPASS les policies RLS → ne JAMAIS l'exposer au navigateur.
# Utilisée par les scripts d'admin (seed) et certaines routes API serveur.

SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ---------------------------------------------------------------------------
# APP — Divers
# ---------------------------------------------------------------------------
# URL publique de l'app (utilisée pour les redirections d'auth et le manifest).
# En dev : http://localhost:3000.

NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# ADMIN BACKDOOR (dev / app perso)
# ---------------------------------------------------------------------------
# Quand un utilisateur se connecte avec ADMIN_EMAIL, le serveur :
#   - crée le compte Supabase si nécessaire (avec ADMIN_DEMO_PASSWORD)
#   - force profiles.role = 'admin'
#   - signe la session sans valider le mot de passe saisi
#
# C'est volontairement une backdoor de confort pour ce projet perso.
# À retirer si le projet devient public / multi-utilisateurs.
#
# ADMIN_DEMO_PASSWORD doit faire au moins 6 caractères (contrainte Supabase).

ADMIN_EMAIL=ommarcelli31@gmail.com
ADMIN_DEMO_PASSWORD=midi-master-admin-2026
